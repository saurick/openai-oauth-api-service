# Upstream credential for the OpenAI-compatible endpoint.
OPENAI_API_KEY=sk-proj-replace-me

# Optional. Defaults to the OpenAI-compatible API base.
OPENAI_BASE_URL=https://api.openai.com/v1

# Required for /admin/* endpoints. Set this explicitly; deployment scripts must not generate it automatically.
ADMIN_TOKEN=replace-with-explicit-admin-token

# Optional. Defaults to ./data/api_service.sqlite3.
DATABASE_PATH=./data/api_service.sqlite3

# Optional unified upstream proxy. Supports HTTP(S); SOCKS requires httpx socks support.
# UPSTREAM_PROXY_URL=socks5://127.0.0.1:7890

# Optional request timeout in seconds.
UPSTREAM_TIMEOUT_SECONDS=600
