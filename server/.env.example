# PostgreSQL DSN for Atlas / Ent
# postgres://user:password@host:port/dbname?sslmode=disable

# 使用方法
# cp .env.example .env
# 然后修改user和password和host和端口
# 然后makefile就可以解析为正确的DB_URL

DB_URL=postgres://test_user:local-password@192.168.0.106:5432/openai_oauth_api_service?sslmode=disable
OAUTH_API_JWT_SECRET=local-dev-jwt-secret
OAUTH_API_ADMIN_USERNAME=admin
OAUTH_API_ADMIN_PASSWORD=adminadmin
OAUTH_API_OAUTH_PROVIDER=google
OAUTH_API_OAUTH_CLIENT_ID=
OAUTH_API_OAUTH_CLIENT_SECRET=
OAUTH_API_OAUTH_ALLOWED_FRONTEND_ORIGINS=
OPENAI_API_KEY=sk-proj-local-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
UPSTREAM_PROXY_URL=
