# 迁移到新服务器时，复制为 .env 并按实际环境调整

# 项目标识（用于容器名等）
PROJECT_SLUG=openai-oauth-api-service

# 应用镜像
APP_IMAGE=openai-oauth-api-service-server:dev

# 时区
TZ=Asia/Shanghai
POSTGRES_MEM_LIMIT=256m
POSTGRES_MEM_RESERVATION=128m
APP_MEM_LIMIT=160m
APP_MEM_RESERVATION=80m
POSTGRES_DSN=postgres://postgres:change-this-postgres-password@postgres:5432/openai_oauth_api_service?sslmode=disable
TRACE_ENDPOINT=
OAUTH_API_JWT_SECRET=change-this-jwt-secret
OAUTH_API_ADMIN_USERNAME=admin
OAUTH_API_ADMIN_PASSWORD=adminadmin

# 上游统一使用服务器 Codex 登录态；默认 codex_backend，失败时自动 fallback 到 codex_cli。
CODEX_HOST_HOME=/root/.codex
CODEX_CONTAINER_HOME=/root/.codex
CODEX_UPSTREAM_MODE=codex_backend
CODEX_CLI_BIN=codex
CODEX_CLI_TIMEOUT_SECONDS=600
CODEX_BACKEND_BASE_URL=https://chatgpt.com/backend-api/codex
CODEX_BACKEND_TIMEOUT_SECONDS=600
CODEX_BACKEND_USER_AGENT=codex-cli
# 默认读取 CODEX_CONTAINER_HOME/auth.json；需要挂载其他路径时再显式指定。
CODEX_AUTH_FILE=
CODEX_REFRESH_TOKEN_URL_OVERRIDE=
# 可选：当 Codex CLI 需要走宿主机代理时配置。示例值适用于宿主机代理监听 Docker bridge 网关。
HTTP_PROXY=
HTTPS_PROXY=
WS_PROXY=
WSS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,postgres,openai-oauth-api-service-postgres
http_proxy=
https_proxy=
ws_proxy=
wss_proxy=
all_proxy=
no_proxy=localhost,127.0.0.1,::1,postgres,openai-oauth-api-service-postgres
NODE_USE_ENV_PROXY=
OAUTH_API_RATE_LIMIT_ENABLED=true
OAUTH_API_EXPORT_MAX_DAYS=90
OAUTH_API_ALERT_RETENTION_DAYS=30

# 可选管理员 OAuth 登录；默认留空即关闭
OAUTH_API_OAUTH_PROVIDER=google
OAUTH_API_OAUTH_CLIENT_ID=
OAUTH_API_OAUTH_CLIENT_SECRET=
OAUTH_API_OAUTH_ALLOWED_FRONTEND_ORIGINS=

# 对外端口
POSTGRES_PORT=5433
APP_HTTP_PORT=8400
APP_GRPC_PORT=9400

# 可选：容器化 Nginx 入口层。当前主路径默认不启用，迁移或切入口时叠加 compose.nginx.yml。
NGINX_IMAGE=nginx:1.27-alpine
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_CERTS_DIR=/data/openai-oauth-api-service/nginx/certs
NGINX_ACME_DIR=/data/openai-oauth-api-service/nginx/acme

# PostgreSQL 参数
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=openai_oauth_api_service
POSTGRES_USER=postgres

# 宿主机数据路径
POSTGRES_DATA_DIR=/data/openai-oauth-api-service/postgres
